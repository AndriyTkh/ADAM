# Copy to .env.local. Vite exposes only VITE_-prefixed vars to the client.

# API base used by the fetch client (api/client.ts).
# Dev: leave empty -> requests go to /v1 and Vite proxies to FastAPI.
# Prod: set to https://api.adam.in.ua
VITE_API_BASE_URL=

# Dev proxy target (server-side only, not shipped to client). See vite.config.ts.
VITE_API_PROXY_TARGET=http://localhost:8000
